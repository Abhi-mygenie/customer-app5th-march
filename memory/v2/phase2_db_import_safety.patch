 import os
@@ -26,6 +36,69 @@ MONGO_URL = os.environ.get("MONGO_URL", "mongodb://localhost:27017")
 DB_NAME = os.environ.get("DB_NAME", "test_database")
 DEFAULT_DATA_DIR = os.path.join(os.path.dirname(__file__), "db_data")
 
+# --- Safety guard (Phase 2 / GAP-010) ---------------------------------------
+# Databases that must NEVER be overwritten without explicit, deliberate opt-in.
+PROTECTED_DB_NAMES = {
+    n.strip() for n in os.environ.get("PROTECTED_DB_NAMES", "mygenie").split(",") if n.strip()
+}
+LOCAL_HOSTS = {"localhost", "127.0.0.1", "::1", "mongo", "mongodb"}
+
+
+def _mongo_host(mongo_url):
+    """Best-effort extraction of the host from a Mongo URL (no external deps)."""
+    try:
+        hostpart = mongo_url.split("://", 1)[1]
+        if "@" in hostpart:
+            hostpart = hostpart.split("@", 1)[1]
+        host = hostpart.split("/", 1)[0].split("?", 1)[0]
+        host = host.split(",", 1)[0].rsplit(":", 1)[0]  # first host, strip port
+        return host.strip("[]").lower()
+    except Exception:
+        return ""
+
+
+def _is_remote(mongo_url):
+    host = _mongo_host(mongo_url)
+    return bool(host) and host not in LOCAL_HOSTS
+
+
+def assert_import_allowed(db_name, mongo_url, dry_run, allow_prod, confirm_db):
+    """Block accidental overwrite of a protected / remote database.
+
+    A dry run is always allowed (no writes). Any write against a protected DB
+    name OR a remote host requires BOTH --allow-prod-overwrite and
+    --confirm-db <DB_NAME> (exact match), plus an interactive typed
+    confirmation when a TTY is attached.
+    """
+    if dry_run:
+        return
+
+    protected = db_name in PROTECTED_DB_NAMES or _is_remote(mongo_url)
+    if not protected:
+        return
+
+    reason = "protected DB name" if db_name in PROTECTED_DB_NAMES else "remote host"
+    print("\n" + "!" * 64)
+    print(f"REFUSING TO WRITE: target database '{db_name}' is a {reason}.")
+    print("db_data/ holds STALE snapshots from other DBs and can DESTROY live data.")
+    print("!" * 64)
+
+    if not (allow_prod and confirm_db == db_name):
+        print("\nTo proceed you MUST pass BOTH of these:")
+        print("  --allow-prod-overwrite")
+        print(f"  --confirm-db {db_name}")
+        print("\nAborting. No changes made.")
+        sys.exit(2)
+
+    # Extra interactive gate when a human is at the terminal.
+    if sys.stdin and sys.stdin.isatty():
+        typed = input(f"Type the database name '{db_name}' to confirm overwrite: ").strip()
+        if typed != db_name:
+            print("Confirmation did not match. Aborting. No changes made.")
+            sys.exit(2)
+
+    print("Override confirmed. Proceeding with import against the protected target.\n")
+
 
